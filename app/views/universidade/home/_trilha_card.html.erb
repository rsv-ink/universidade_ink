<%
  progresso     = trilha.progresso_lojista(universidade_current_user.id, universidade_current_user.store_id)
  progresso_pct = (progresso * 100).round
%>

<%= link_to trilha_path(trilha), class: "group flex flex-col justify-center h-full bg-white rounded-xl border border-gray-200 hover:border-pink-300 hover:shadow-md transition-all overflow-hidden" do %>

  <%# Imagem da trilha %>
  <% if trilha.imagem.attached? %>
    <div class="w-full overflow-hidden bg-gray-100">
      <%= image_tag main_app.url_for(trilha.imagem), class: "w-full h-auto group-hover:scale-105 transition-transform duration-300" %>
    </div>
  <% end %>

  <div class="p-5">
    <%# Tags %>
    <% if trilha.tags.any? %>
      <div class="flex flex-wrap gap-1 mb-3">
        <% trilha.tags.each do |tag| %>
          <%= badge_component(color: :blue, size: :xs, shape: :pill) { tag } %>
        <% end %>
      </div>
    <% end %>

    <%# Nome %>
    <h3 class="font-semibold text-gray-900 group-hover:text-pink-600 transition-colors leading-snug mb-1">
      <%= trilha.nome %>
    </h3>

    <%# Descrição %>
    <% if trilha.descricao.present? %>
      <p class="text-sm text-gray-500 line-clamp-2 mb-4"><%= trilha.descricao %></p>
    <% else %>
      <div class="mb-4"></div>
    <% end %>

    <%# Barra de progresso %>
    <div class="mt-auto">
      <div class="flex items-center justify-between text-xs text-gray-500 mb-1">
        <span>Progresso</span>
        <span class="font-medium <%= progresso_pct == 100 ? 'text-green-600' : 'text-gray-600' %>">
          <%= progresso_pct %>%
        </span>
      </div>
      <div class="w-full bg-gray-100 rounded-full h-1.5">
        <div class="h-1.5 rounded-full transition-all <%= progresso_pct == 100 ? 'bg-green-500' : 'bg-pink-500' %>"
             style="width: <%= progresso_pct %>%"></div>
      </div>
    </div>
  </div>

<% end %>
