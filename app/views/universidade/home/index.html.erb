<% if @secoes.any? %>

  <%# ————— LANDING PAGE COM SEÇÕES CONFIGURADAS ————— %>
  <% @secoes.each do |secao| %>
    <%= render "secao", secao: secao %>
  <% end %>

<% else %>

  <%# ————— FALLBACK: exibição padrão ————— %>

  <%# ————— TRILHAS ————— %>
  <section>
    <h1 class="text-3xl font-bold text-gray-900 mb-1">Trilhas</h1>
    <p class="text-gray-500 text-sm mb-8">Explore as trilhas disponíveis e acompanhe o seu progresso.</p>

    <% if @trilhas && @trilhas.any? %>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
        <% @trilhas.each do |trilha| %>
          <%= render "trilha_card", trilha: trilha %>
        <% end %>
      </div>
    <% else %>
      <div class="text-center py-16 bg-white rounded-xl border border-gray-200">
        <p class="text-gray-400 text-sm">Nenhuma trilha disponível no momento.</p>
      </div>
    <% end %>
  </section>

  <%# ————— CONTEÚDOS SOLTOS ————— %>
  <% if @conteudos_soltos && @conteudos_soltos.any? %>
    <section class="mt-14">
      <h2 class="text-xl font-bold text-gray-900 mb-1">Conteúdos</h2>
      <p class="text-gray-500 text-sm mb-6">Leituras avulsas recomendadas.</p>

      <div class="space-y-2">
        <% @conteudos_soltos.each do |conteudo| %>
          <%= render "conteudo_item", conteudo: conteudo %>
        <% end %>
      </div>
    </section>
  <% end %>

<% end %>
