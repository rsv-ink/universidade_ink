<% if @secoes.any? %>

  <%# ————— LANDING PAGE COM SEÇÕES CONFIGURADAS ————— %>
  <% @secoes.each do |secao| %>
    <%= render "secao", secao: secao %>
  <% end %>

<% else %>

  <%# ————— FALLBACK: exibição padrão ————— %>

  <%# ————— FILTROS DE TAXONOMIA ————— %>
  <div class="mb-8 p-4 bg-white rounded-xl border border-gray-200">
    <%= form_with url: root_path, method: :get, local: true, class: "flex flex-wrap gap-3 items-end" do |f| %>
      <div class="flex-1 min-w-[200px]">
        <%= f.label :categoria_id, "Filtrar por Categoria", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.select :categoria_id,
              options_for_select(
                [["Todas as categorias", ""]] + 
                @categorias.map { |c| [c.nome, c.id] },
                @categoria_selecionada
              ),
              {},
              {
                class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-pink-300 focus:border-transparent",
                onchange: "this.form.requestSubmit()"
              } %>
      </div>
      
      <div class="flex-1 min-w-[200px]">
        <%= f.label :tag_ids, "Filtrar por Tags", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.select :tag_ids,
              options_for_select(
                @tags.map { |t| [t.nome, t.id] },
                @tags_selecionadas
              ),
              {},
              {
                multiple: true,
                class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-pink-300 focus:border-transparent"
              } %>
      </div>
      
      <div class="flex gap-2">
        <%= f.submit "Filtrar", class: "px-4 py-2 bg-pink-600 text-white rounded-lg hover:bg-pink-700 transition" %>
        <% if @categoria_selecionada.present? || @tags_selecionadas.any? %>
          <%= link_to "Limpar", root_path, class: "px-4 py-2 border border-gray-300 rounded-lg hover:bg-gray-50 transition" %>
        <% end %>
      </div>
    <% end %>
    
    <%# Mostrar filtros ativos %>
    <% if @categoria_selecionada.present? || @tags_selecionadas.any? %>
      <div class="mt-3 flex flex-wrap gap-2 items-center">
        <span class="text-sm text-gray-600">Filtrando por:</span>
        <% if @categoria_selecionada.present? %>
          <% categoria = @categorias.find { |c| c.id.to_s == @categoria_selecionada.to_s } %>
          <span class="inline-flex items-center gap-1 px-3 py-1 bg-pink-100 text-pink-700 text-sm rounded-full">
            <%= categoria&.nome %>
          </span>
        <% end %>
        <% if @tags_selecionadas.any? %>
          <% @tags_selecionadas.each do |tag_id| %>
            <% tag = @tags.find { |t| t.id.to_s == tag_id.to_s } %>
            <span class="inline-flex items-center gap-1 px-3 py-1 bg-blue-100 text-blue-700 text-sm rounded-full">
              <%= tag&.nome %>
            </span>
          <% end %>
        <% end %>
      </div>
    <% end %>
  </div>

  <%# ————— TRILHAS ————— %>
  <section>
    <h1 class="text-3xl font-bold text-gray-900 mb-1">Trilhas</h1>
    <p class="text-gray-500 text-sm mb-8">Explore as trilhas disponíveis e acompanhe o seu progresso.</p>

    <% if @trilhas && @trilhas.any? %>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
        <% @trilhas.each do |trilha| %>
          <%= render "trilha_card", trilha: trilha %>
        <% end %>
      </div>
    <% else %>
      <div class="text-center py-16 bg-white rounded-xl border border-gray-200">
        <p class="text-gray-400 text-sm">Nenhuma trilha disponível no momento.</p>
      </div>
    <% end %>
  </section>

  <%# ————— CONTEÚDOS SOLTOS ————— %>
  <% if @conteudos_soltos && @conteudos_soltos.any? %>
    <section class="mt-14">
      <h2 class="text-xl font-bold text-gray-900 mb-1">Conteúdos</h2>
      <p class="text-gray-500 text-sm mb-6">Leituras avulsas recomendadas.</p>

      <div class="space-y-2">
        <% @conteudos_soltos.each do |conteudo| %>
          <%= render "conteudo_item", conteudo: conteudo %>
        <% end %>
      </div>
    </section>
  <% end %>

<% end %>
