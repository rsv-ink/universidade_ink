<%# JSON-LD Structured Data %>
<% content_for :json_ld do %>
  <%= json_ld_course(@trilha) %>
  <%
    breadcrumb_items = [
      { name: "Início", url: root_url },
      { name: @trilha.nome, url: trilha_url(@trilha) }
    ]
  %>
  <%= json_ld_breadcrumbs(breadcrumb_items) %>
<% end %>

<%# ————— Breadcrumb ————— %>
<nav class="flex items-center gap-2 text-sm text-gray-500 mb-8">
  <%= link_to "Trilhas", root_path, class: "hover:text-pink-600 transition-colors" %>
  <span class="text-gray-300">/</span>
  <span class="text-gray-700 font-medium"><%= @trilha.nome %></span>
</nav>

<%# ————— Cabeçalho da Trilha ————— %>
<div class="mb-10">
  <%# Tags %>
  <% if @trilha.tags.any? %>
    <div class="flex flex-wrap gap-1.5 mb-3">
      <% @trilha.tags.each do |tag| %>
        <%= badge_component(color: :blue, size: :xs, shape: :pill) { tag } %>
      <% end %>
    </div>
  <% end %>

  <h1 class="text-3xl font-bold text-gray-900 mb-2"><%= @trilha.nome %></h1>

  <% if @trilha.descricao.present? %>
    <p class="text-gray-600 text-base leading-relaxed max-w-2xl"><%= @trilha.descricao %></p>
  <% end %>

  <%# Progresso geral da trilha %>
  <%
    trilha_pct = (@trilha.progresso_lojista(universidade_current_user.id, universidade_current_user.store_id) * 100).round
    concluido = trilha_pct == 100
  %>
    <div class="mt-6 flex items-center gap-4 bg-white border border-gray-200 rounded-xl px-5 py-3">
      <div class="flex-1 bg-gray-100 rounded-full h-2">
        <div class="h-2 rounded-full transition-all <%= concluido ? 'bg-green-500' : 'bg-pink-500' %>"
             style="width: <%= trilha_pct %>%"></div>
      </div>
      <span class="text-sm font-semibold <%= concluido ? 'text-green-600' : 'text-gray-700' %> whitespace-nowrap">
        <%= trilha_pct %>% concluído
      </span>
      <% if concluido %>
        <%= badge_component(color: :green, size: :xs, shape: :pill) { "Completo" } %>
      <% end %>
    </div>
</div>

<%# ————— Módulos ————— %>
<% if @modulos.any? %>
  <div class="space-y-4">
    <% @modulos.each do |modulo| %>
      <%
        mod_progresso     = modulo.progresso(universidade_current_user.id, universidade_current_user.store_id)
        mod_progresso_pct = (mod_progresso * 100).round
        conteudos_visiveis = @modulos_conteudos[modulo.id] || []
      %>

      <div class="bg-white rounded-xl border border-gray-200 overflow-hidden">

        <%# Cabeçalho do módulo %>
        <div class="px-6 py-4 border-b border-gray-100 flex items-center justify-between gap-4">
          <div class="flex-1 min-w-0">
            <h2 class="font-semibold text-gray-900 text-base"><%= modulo.nome %></h2>
            <% if modulo.descricao.present? %>
              <p class="text-xs text-gray-400 mt-0.5 truncate"><%= modulo.descricao %></p>
            <% end %>
          </div>

          <%# Progresso do módulo (conteúdos concluídos / total) %>
          <div class="flex items-center gap-3 flex-shrink-0">
            <% conteudos_total = conteudos_visiveis.size %>
            <span class="text-xs text-gray-400">
              <% conteudos_concluidos = conteudos_visiveis.count { |c| c.concluido?(universidade_current_user.id, universidade_current_user.store_id) } %>
              <%= conteudos_concluidos %> / <%= conteudos_total %> conteúdo<%= conteudos_total == 1 ? '' : 's' %>
            </span>
            <div class="w-24 bg-gray-100 rounded-full h-1.5">
              <div class="h-1.5 rounded-full <%= mod_progresso_pct == 100 ? 'bg-green-500' : 'bg-pink-500' %>"
                   style="width: <%= mod_progresso_pct %>%"></div>
            </div>
            <span class="text-xs font-medium text-gray-500 w-8 text-right">
              <%= mod_progresso_pct %>%
            </span>
          </div>
        </div>

        <%# Lista de conteúdos do módulo %>
        <% if conteudos_visiveis.any? %>
          <ul class="divide-y divide-gray-50">
            <% conteudos_visiveis.each do |conteudo| %>
              <%
                c_concluido = conteudo.concluido?(universidade_current_user.id, universidade_current_user.store_id)
              %>

              <li>
                <%= link_to conteudo_path(conteudo), class: "flex items-center gap-4 px-6 py-3.5 hover:bg-gray-50 transition-colors group" do %>

                  <%# Status icon %>
                  <div class="flex-shrink-0 w-7 h-7 rounded-full flex items-center justify-center text-sm
                              <%= c_concluido ? 'bg-green-100 text-green-600' : 'bg-gray-100 text-gray-400 group-hover:bg-pink-50 group-hover:text-pink-500' %>">
                    <% if c_concluido %>
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
                      </svg>
                    <% else %>
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                              d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"/>
                      </svg>
                    <% end %>
                  </div>

                  <%# Nome e tempo estimado %>
                  <div class="flex-1 min-w-0">
                    <p class="text-sm font-medium text-gray-900 group-hover:text-pink-600 transition-colors truncate"><%= conteudo.titulo %></p>
                    <% if conteudo.tempo_estimado_minutos.present? %>
                      <p class="text-xs text-gray-400 mt-0.5"><%= conteudo.tempo_estimado_minutos %> min</p>
                    <% end %>
                  </div>

                  <%# Status de conclusão %>
                  <div class="flex items-center gap-2 flex-shrink-0">
                    <% if c_concluido %>
                      <span class="text-xs text-green-600 font-medium">Concluído</span>
                    <% else %>
                      <span class="text-xs text-gray-400">Pendente</span>
                    <% end %>
                  </div>

                  <%# Seta de navegação %>
                  <svg class="flex-shrink-0 w-4 h-4 text-gray-300 group-hover:text-pink-400 transition-colors" 
                       fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                  </svg>

                <% end %>
              </li>
            <% end %>
          </ul>
        <% else %>
          <p class="px-6 py-4 text-sm text-gray-400 italic">Este módulo ainda não possui conteúdos.</p>
        <% end %>

      </div>
    <% end %>
  </div>
<% else %>
  <div class="text-center py-16 bg-white rounded-xl border border-gray-200">
    <p class="text-gray-400 text-sm">Esta trilha ainda não possui módulos.</p>
  </div>
<% end %>
