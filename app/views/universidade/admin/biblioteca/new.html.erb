<div class="px-6 py-6 max-w-7xl mx-auto">
  <div class="flex items-center justify-between mb-4">
    <div>
      <h1 class="text-2xl font-bold text-gray-900">Novo Conteúdo</h1>
      <p class="text-sm text-gray-500 mt-1">Crie um novo conteúdo para a biblioteca</p>
    </div>
    <%= link_to admin_biblioteca_index_path,
          class: "text-sm text-gray-500 hover:text-pink-600 transition-colors flex items-center gap-1" do %>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
      </svg>
      Voltar para Biblioteca
    <% end %>
  </div>

  <%= form_with model: @conteudo, url: admin_biblioteca_index_path do |f| %>
    <%# Informações Básicas %>
    <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-6 mb-6">
      <h2 class="text-lg font-semibold text-gray-900 mb-4">Informações Básicas</h2>

      <%# Título %>
      <div class="mb-4">
        <%= f.label :titulo, "Título do Conteúdo", class: "block text-sm font-medium text-gray-700 mb-2" %>
        <%= f.text_field :titulo, 
              class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-pink-300 focus:border-transparent",
              placeholder: "Digite o título do conteúdo..." %>
        <% if @conteudo.errors[:titulo].any? %>
          <p class="mt-1 text-sm text-red-600"><%= @conteudo.errors[:titulo].first %></p>
        <% end %>
      </div>

      <%# Metadados em Grid %>
      <div class="grid grid-cols-3 gap-4">
        <div>
          <%= f.label :tempo_estimado_minutos, "Tempo de leitura (min)", class: "block text-sm font-medium text-gray-700 mb-2" %>
          <%= f.number_field :tempo_estimado_minutos,
                class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-pink-300 focus:border-transparent",
                placeholder: "0" %>
        </div>
        <div class="col-span-2 flex items-end">
          <div class="flex items-center gap-3">
            <%= f.check_box :visivel, class: "w-4 h-4 text-pink-600 border-gray-300 rounded focus:ring-pink-500" %>
            <%= f.label :visivel, "Conteúdo visível para os lojistas", class: "text-sm font-medium text-gray-700" %>
          </div>
        </div>
      </div>
    </div>

    <%# Vincular Trilhas %>
    <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-6 mb-6"
         data-controller="trilhas-manager"
         data-trilhas-manager-modulos-value='<%= @modulos_json %>'>
      <h2 class="text-lg font-semibold text-gray-900 mb-1">Trilhas</h2>
      <p class="text-sm text-gray-500 mb-4">Opcional: Vincule este conteúdo a uma ou mais trilhas e organize em módulos</p>

      <%# Dropdown de Trilhas %>
      <div class="relative mb-4">
        <label class="block text-sm font-medium text-gray-700 mb-2">
          Adicionar Trilhas <span data-trilhas-manager-target="selectedCount" class="text-pink-600"></span>
        </label>
        <div class="relative">
          <button type="button"
                  data-action="click->trilhas-manager#toggleDropdown"
                  class="w-full px-3 py-2 text-left border border-gray-300 rounded-lg bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-pink-300 focus:border-transparent flex items-center justify-between">
            <span class="text-gray-700">Selecione as trilhas...</span>
            <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
            </svg>
          </button>

          <div data-trilhas-manager-target="trilhasDropdown"
                 class="hidden absolute z-10 w-full mt-1 bg-white border border-gray-300 rounded-lg shadow-lg">
              <div class="p-3 border-b border-gray-200">
                <input type="text"
                       data-trilhas-manager-target="searchInput"
                       data-action="input->trilhas-manager#filterTrilhas"
                       placeholder="Buscar trilhas..."
                       class="w-full px-3 py-2 text-sm border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-pink-300 focus:border-transparent">
              </div>
              <div class="p-3 space-y-2 max-h-56 overflow-auto" data-trilhas-manager-target="trilhasContainer">
              <% @trilhas.each do |trilha| %>
                <label class="flex items-center gap-2 p-2 hover:bg-gray-50 rounded cursor-pointer">
                  <input type="checkbox" 
                         value="<%= trilha.id %>"
                         data-trilha-nome="<%= trilha.nome %>"
                         data-action="change->trilhas-manager#toggleTrilha"
                         class="w-4 h-4 text-pink-600 border-gray-300 rounded focus:ring-pink-500">
                  <span class="text-sm text-gray-900"><%= trilha.nome %></span>
                </label>
              <% end %>
            </div>
            <div class="border-t border-gray-200 p-3 bg-gray-50 flex justify-end gap-2">
              <button type="button"
                      data-action="click->trilhas-manager#closeDropdown"
                      class="px-3 py-1.5 text-sm text-gray-600 hover:text-gray-800">
                Cancelar
              </button>
              <button type="button"
                      data-trilhas-manager-target="applyButton"
                      data-action="click->trilhas-manager#aplicar"
                      class="px-3 py-1.5 text-sm text-white bg-pink-600 rounded hover:bg-pink-700 disabled:opacity-50 disabled:cursor-not-allowed">
                Aplicar
              </button>
            </div>
          </div>
        </div>
      </div>

      <%# Lista de Trilhas Vinculadas %>
      <div data-trilhas-manager-target="trilhasList" class="space-y-2">
        <%# Trilhas serão adicionadas aqui dinamicamente %>
      </div>
    </div>

    <%# Editor de blocos %>
    <div class="bg-white rounded-xl border border-gray-200 shadow-sm mb-6">
      <div class="p-6">
        <h2 class="text-lg font-semibold text-gray-900">Conteúdo</h2>
        <p class="text-sm text-gray-500 mt-1">Arraste blocos da paleta para compor seu conteúdo</p>
      </div>

      <div data-controller="blocks-editor"
           data-blocks-editor-upload-url-value="<%= admin_rich_image_upload_path %>">

        <input type="hidden" name="conteudo[corpo]" id="conteudo_corpo"
               value="<%= h(@conteudo.corpo) %>"
               data-blocks-editor-target="hidden">

        <div class="blocks-layout">
          <%# ── Palette (sidebar de tipos de bloco) ──────────────────── %>
          <div class="blocks-palette-col">
            <div class="blocks-palette-card">
              <div style="display: flex; align-items: center; gap: 8px; margin-bottom: 14px;">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#6b7280" stroke-width="2.5" style="flex-shrink: 0;">
                  <path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
                  <path d="M13 17l-4-4m0 0l4-4m-4 4h8"/>
                </svg>
                <p class="blocks-palette-heading" style="margin: 0; padding: 0; border: none;">Arraste →</p>
              </div>
              <div data-blocks-editor-target="palette" class="blocks-palette-grid">
                <% [
                  ["titulo",   "T",     "Título"],
                  ["texto",    "¶",     "Texto"],
                  ["citacao",  "\u201C","Citação"],
                  ["codigo",   "</>",   "Código"],
                  ["imagem",   "▣",     "Imagem"],
                  ["video",    "▶",     "Vídeo"],
                  ["divisor",  "—",     "Divisor"],
                  ["destaque", "◈",     "Destaque"],
                ].each do |type, icon, label| %>
                  <div class="palette-item" data-block-type="<%= type %>">
                    <span class="palette-item-icon"><%= icon %></span>
                    <span class="palette-item-label"><%= label %></span>
                  </div>
                <% end %>
              </div>
            </div>
          </div>

          <%# ── Canvas (coluna principal) ─────────────────────────────── %>
          <div class="blocks-canvas-col">
            <div class="blocks-editor-wrapper">
              <div class="blocks-canvas-wrapper">
                <div data-blocks-editor-target="canvas" class="blocks-canvas">
                  <div data-blocks-editor-target="emptyState" class="blocks-empty-state">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                      <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" 
                            d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                    </svg>
                    <p class="blocks-empty-state-text">Comece arrastando um bloco</p>
                    <p class="blocks-empty-state-hint">
                      Escolha um tipo de bloco à esquerda e arraste para esta área para começar a compor seu conteúdo
                    </p>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <%# Ações %>
    <div class="flex items-center justify-end gap-3 pt-4 border-t border-gray-200">
      <%= link_to "Cancelar", admin_biblioteca_index_path,
            class: "px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-lg hover:bg-gray-50 transition-colors" %>
      
      <%= f.hidden_field :status_action, id: "status_action", value: "rascunho" %>
      <%= f.submit "Salvar como rascunho",
            onclick: "document.getElementById('status_action').value='rascunho'",
            class: "px-4 py-2 text-sm font-medium text-gray-700 bg-gray-100 rounded-lg hover:bg-gray-200 transition-colors" %>
      <%= f.submit "Publicar",
            onclick: "document.getElementById('status_action').value='publicar'",
            class: "px-4 py-2 text-sm font-medium text-white bg-pink-600 rounded-lg hover:bg-pink-700 transition-colors" %>
    </div>
  <% end %>
</div>
