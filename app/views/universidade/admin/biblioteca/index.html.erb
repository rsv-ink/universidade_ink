<%# ── Header ──────────────────────────────────────────────────── %>
<div class="px-6 py-6 max-w-7xl mx-auto">
  <div class="flex items-center justify-between mb-4">
    <div>
      <h1 class="text-2xl font-bold text-gray-900">Biblioteca de Conteúdos</h1>
      <p class="text-sm text-gray-500 mt-1">Todos os conteúdos cadastrados, independente de vínculo com trilhas</p>
    </div>
  </div>

  <%# ── Busca de conteúdo ── %>
  <%= form_with url: admin_biblioteca_index_path, method: :get, local: true,
        class: "flex items-center gap-2 mb-6" do |f| %>
    <%= f.search_field :q, placeholder: "Buscar conteúdos...",
          value: params[:q],
          class: "text-sm border border-gray-200 rounded-lg px-3 py-2 w-80 focus:outline-none focus:ring-2 focus:ring-pink-300 focus:border-transparent" %>
    <button type="submit"
            class="inline-flex items-center gap-1.5 px-4 py-2 bg-white hover:bg-gray-50 text-gray-600 text-sm font-medium rounded-lg transition-colors border border-gray-200">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-4.35-4.35M17 11A6 6 0 1 1 5 11a6 6 0 0 1 12 0z"/>
      </svg>
      Buscar
    </button>
  <% end %>

  <%# ── Tabela de conteúdos ───────────────────────────────────── %>
  <div class="flex items-center justify-between mb-4">
    <div class="flex items-center gap-3">
      <p class="text-xs text-gray-500"><%= @conteudos.size %> conteúdo(s)</p>
    </div>
    <%= link_to new_admin_biblioteca_path,
          class: "inline-flex items-center gap-2 px-4 py-2 bg-pink-600 hover:bg-pink-700 text-white text-sm font-medium rounded-lg transition-colors" do %>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
      </svg>
      Novo Conteúdo
    <% end %>
  </div>

  <div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden">
    <table class="w-full text-sm text-left text-gray-600">
      <thead class="text-xs font-semibold text-gray-500 uppercase tracking-wider bg-gray-50 border-b border-gray-200">
        <tr>
          <th class="px-4 py-3">Título</th>
          <th class="px-4 py-3 w-48 text-center">Vínculos</th>
          <th class="px-4 py-3 w-32 text-center">Status</th>
          <th class="px-4 py-3 w-40 text-right">Ações</th>
        </tr>
      </thead>

      <% if @conteudos.empty? %>
        <tbody>
          <tr>
            <td colspan="4" class="px-4 py-16 text-center text-gray-400 text-sm">
              Nenhum conteúdo cadastrado ainda.
              <%= link_to "Criar o primeiro conteúdo", new_admin_biblioteca_path,
                    class: "text-pink-600 hover:underline font-medium" %>
            </td>
          </tr>
        </tbody>
      <% else %>
        <tbody>
          <% @conteudos.each do |conteudo| %>
            <%= render "conteudo_row", conteudo: conteudo %>
          <% end %>
        </tbody>
      <% end %>
    </table>
  </div>
</div>
