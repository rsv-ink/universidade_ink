<div class="bg-white px-6 py-4 border-b border-gray-200">
  <h2 class="text-xl font-semibold text-gray-900">
    <%= @tag.new_record? ? "Nova Tag" : "Editar Tag" %>
  </h2>
</div>

<div class="p-6">
  <%= form_with model: @tag,
    url: @tag.new_record? ? admin_tags_path : admin_tag_path(@tag),
    data: { turbo_stream: true, action: "turbo:submit-end->modal#close turbo:submit-end->modal#reloadOnSuccess" },
    class: "space-y-5" do |f| %>

    <% if @tag.errors.any? %>
      <div class="rounded-md bg-red-50 p-4 border border-red-200">
        <div class="flex">
          <div class="ml-3">
            <h3 class="text-sm font-medium text-red-800">
              <%= @tag.errors.count %> erro(s) impediram o salvamento:
            </h3>
            <div class="mt-2 text-sm text-red-700">
              <ul class="list-disc list-inside space-y-1">
                <% @tag.errors.full_messages.each do |msg| %>
                  <li><%= msg %></li>
                <% end %>
              </ul>
            </div>
          </div>
        </div>
      </div>
    <% end %>

    <%# Nome %>
    <div>
      <label for="tag_nome" class="block text-sm font-medium text-gray-700 mb-1">
        Nome *
      </label>
      <%= f.text_field :nome,
          id: "tag_nome",
          class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent #{@tag.errors[:nome].any? ? 'border-red-500' : ''}",
          placeholder: "Ex: instagram, iniciante, meta-ads" %>
      <% if @tag.errors[:nome].any? %>
        <p class="mt-1 text-sm text-red-600"><%= @tag.errors[:nome].first %></p>
      <% end %>
      <p class="mt-1 text-xs text-gray-500">Use letras minúsculas e hífens. O slug será gerado automaticamente.</p>
    </div>

    <%# Botões %>
    <div class="flex justify-end gap-3 pt-4 border-t">
      <%= link_to "Cancelar", 
                  "#", 
                  class: "px-4 py-2 border border-gray-300 rounded-lg text-gray-700 hover:bg-gray-50",
                  data: { action: "modal#close" } %>
      <%= f.submit @tag.new_record? ? "Criar Tag" : "Salvar Alterações",
          class: "px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700" %>
    </div>
  <% end %>
</div>
