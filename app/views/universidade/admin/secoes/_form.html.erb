<%# locals: (secao:, trilhas:, conteudos:, url:) %>

<%# Header %>
<div class="mb-6">
  <h2 class="text-xl font-semibold text-gray-900">
    <%= secao.new_record? ? "Nova Seção" : "Editar Seção" %>
  </h2>
  <p class="text-sm text-gray-500 mt-1">
    Configure as informações e conteúdo da seção da landing page
  </p>
</div>

<%= form_with model: secao, url: url, method: (secao.new_record? ? :post : :patch),
  data: { controller: "secao-form", action: "turbo:submit-end->modal#close turbo:submit-end->modal#reloadOnSuccess" },
      class: "space-y-5" do |f| %>

  <%# Erros %>
  <% if secao.errors.any? %>
    <div class="bg-red-50 border border-red-200 text-red-700 rounded-lg p-4 text-sm">
      <ul class="list-disc list-inside space-y-1">
        <% secao.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <%# ══════════════════════════════════════════════════════ %>
  <%# INFORMAÇÕES BÁSICAS %>
  <%# ══════════════════════════════════════════════════════ %>
  <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-6 space-y-4">
    <div class="mb-4">
      <h3 class="text-sm font-semibold text-gray-900">Informações Básicas</h3>
      <p class="text-xs text-gray-500 mt-0.5">Título e subtítulo da seção</p>
    </div>

    <%# Título %>
    <div>
      <%= f.label :titulo, "Título da seção (opcional)", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_field :titulo,
            placeholder: "Ex: Trilhas em destaque",
            class: "w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-pink-500 focus:border-pink-500" %>
      <p class="text-xs text-gray-400 mt-1">Deixe em branco para ocultar o título.</p>
    </div>

    <%# Subtítulo %>
    <div>
      <%= f.label :subtitulo, "Subtítulo (opcional)", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_field :subtitulo,
            placeholder: "Ex: Conteúdos recomendados para você",
            class: "w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-pink-500 focus:border-pink-500" %>
    </div>
  </div>

  <%# ══════════════════════════════════════════════════════ %>
  <%# CONFIGURAÇÕES DE EXIBIÇÃO %>
  <%# ══════════════════════════════════════════════════════ %>
  <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-6 space-y-5">
    <div class="mb-2">
      <h3 class="text-sm font-semibold text-gray-900">Configurações de Exibição</h3>
      <p class="text-xs text-gray-500 mt-0.5">Tipo, layout e quantidade de itens por linha</p>
    </div>
      <%# Tipo de seção %>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-2">Tipo de seção</label>
        <div class="grid grid-cols-2 gap-3">
          <% [["conteudo", "Conteúdo", "Grade de trilhas ou conteúdos"], ["imagem", "Imagem", "Banner, foto ou ilustração"]].each do |val, label, desc| %>
            <label class="flex items-start gap-3 p-3 border border-gray-300 rounded-lg cursor-pointer hover:border-pink-400 transition-colors has-[:checked]:border-pink-500 has-[:checked]:bg-pink-50">
              <%= f.radio_button :tipo, val,
                    class: "mt-0.5 text-pink-600 focus:ring-pink-500",
                    data: { action: "change->secao-form#onTipoChange" } %>
              <div>
                <p class="text-sm font-medium text-gray-900"><%= label %></p>
                <p class="text-xs text-gray-500 mt-0.5"><%= desc %></p>
              </div>
            </label>
          <% end %>
        </div>
      </div>

      <%# Layout de exibição %>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-2">Layout de exibição</label>
        <div class="grid grid-cols-2 gap-3">
          <% [["carrossel", "Carrossel", "Navegação por setas"], ["galeria", "Galeria", "Todos os itens visíveis"]].each do |val, label, desc| %>
            <label class="flex items-start gap-3 p-3 border border-gray-300 rounded-lg cursor-pointer hover:border-pink-400 transition-colors has-[:checked]:border-pink-500 has-[:checked]:bg-pink-50">
              <%= f.radio_button :layout_exibicao, val,
                class: "mt-0.5 text-pink-600 focus:ring-0 focus:outline-none" %>
              <div>
                <p class="text-sm font-medium text-gray-900"><%= label %></p>
                <p class="text-xs text-gray-500 mt-0.5"><%= desc %></p>
              </div>
            </label>
          <% end %>
        </div>
      </div>

      <%# Cards por linha — Desktop e Mobile %>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-3">Itens por linha</label>
        <div class="grid grid-cols-2 gap-4">

          <%# Desktop %>
          <div>
            <p class="text-xs font-semibold text-gray-500 mb-2 flex items-center gap-1.5">
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
              </svg>
              Desktop
            </p>
            <div class="grid grid-cols-4 gap-1.5">
              <% [1, 2, 3, 4].each do |val| %>
                <label class="flex items-center justify-center p-2 border border-gray-300 rounded-lg cursor-pointer hover:border-pink-400 transition-colors has-[:checked]:border-pink-500 has-[:checked]:bg-pink-50">
                  <%= f.radio_button :colunas_galeria, val, class: "sr-only" %>
                  <span class="text-sm font-medium text-gray-900"><%= val %></span>
                </label>
              <% end %>
            </div>
          </div>

          <%# Mobile %>
          <div>
            <p class="text-xs font-semibold text-gray-500 mb-2 flex items-center gap-1.5">
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z"/>
              </svg>
              Mobile
            </p>
            <div class="grid grid-cols-4 gap-1.5">
              <% [1, 2, 3, 4].each do |val| %>
                <label class="flex items-center justify-center p-2 border border-gray-300 rounded-lg cursor-pointer hover:border-pink-400 transition-colors has-[:checked]:border-pink-500 has-[:checked]:bg-pink-50">
                  <%= f.radio_button :colunas_galeria_mobile, val, class: "sr-only" %>
                  <span class="text-sm font-medium text-gray-900"><%= val %></span>
                </label>
              <% end %>
            </div>
          </div>

        </div>
        <p class="text-xs text-gray-400 mt-2">Define quantos cards serão exibidos por linha em cada dispositivo.</p>
      </div>

      <%= f.hidden_field :formato_card, value: "quadrado" %>
    </div>
  </div>

  <%# ══════════════════════════════════════════════════════ %>
  <%# CONTEÚDO DA SEÇÃO %>
  <%# ══════════════════════════════════════════════════════ %>
  <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-6 space-y-4">
    <div class="mb-4">
      <h3 class="text-sm font-semibold text-gray-900">Conteúdo da Seção</h3>
      <p class="text-xs text-gray-500 mt-0.5">Selecione imagens ou conteúdos para exibir</p>
    </div>
    <div>
      <%# ── Painel: Imagens ──────────────────────────────────── %>
      <div data-secao-form-target="imagemPanel">
        
        <!-- Preview de imagens existentes -->
        <% if secao.persisted? && secao.imagens.attached? %>
          <div class="mb-4">
            <p class="text-sm font-medium text-gray-700 mb-3">Imagens anexadas</p>
            <div class="grid grid-cols-2 sm:grid-cols-3 gap-3" data-secao-form-target="imagensList">
              <% secao.imagens_ordenadas.each do |img| %>
                <div class="secao-imagem-item relative group bg-gray-50 border border-gray-100 rounded-lg p-2">
                  <%= hidden_field_tag "secao[imagens_ordem][]", img.blob_id %>
                  
                  <div class="relative mb-2">
                    <div class="absolute top-2 left-2 text-white/70 bg-black/30 rounded-md p-1 cursor-grab active:cursor-grabbing z-10" data-sortable-handle>
                      <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                              d="M9 6h.01M9 12h.01M9 18h.01M15 6h.01M15 12h.01M15 18h.01"/>
                      </svg>
                    </div>
                    <button type="button" 
                            class="absolute top-2 right-2 text-white bg-red-500 hover:bg-red-600 rounded-md p-1 z-10"
                            data-action="click->secao-form#removeImage">
                      <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                      </svg>
                    </button>
                    <%= image_tag main_app.url_for(img),
                          class: "w-full h-28 rounded-lg border border-gray-200 object-cover" %>
                    <% if img.blob.metadata["size_kb"] %>
                      <span class="absolute bottom-2 left-2 bg-black/70 text-white text-xs px-2 py-1 rounded z-10">
                        <%= img.blob.metadata["size_kb"] %> KB
                      </span>
                    <% end %>
                  </div>

                  <div class="mt-2">
                    <%= text_field_tag "secao[imagens_links][#{img.blob_id}]", 
                          secao.imagens_links&.dig(img.blob_id.to_s), 
                          placeholder: "https://exemplo.com",
                          class: "w-full border border-gray-200 rounded px-2 py-1.5 text-xs focus:ring-pink-500 focus:border-pink-500" %>
                  </div>
                </div>
              <% end %>
            </div>
            <p class="text-xs text-gray-400 mt-2">Arraste para reordenar as imagens.</p>
          </div>
        <% end %>
        
        <!-- Container para preview de novas imagens -->
        <div class="mb-4 hidden" data-secao-form-target="previewContainer">
          <p class="text-sm font-medium text-gray-700 mb-3">Novas imagens</p>
          <div class="grid grid-cols-2 sm:grid-cols-3 gap-3" data-secao-form-target="previewList"></div>
          <p class="text-xs text-gray-400 mt-2">Arraste para reordenar as imagens. Adicione links se desejar.</p>
        </div>
        
        <!-- Upload de imagens -->
        <div>
          <p class="text-sm font-medium text-gray-700 mb-3">
            <%= secao.persisted? && secao.imagens.attached? ? "Adicionar mais imagens" : "Upload de imagens" %>
          </p>
          <div class="flex items-center justify-center w-full">
            <label for="secao_imagens" class="flex flex-col items-center justify-center w-full h-40 border-2 border-pink-300 border-dashed rounded-lg cursor-pointer bg-pink-50 hover:bg-pink-100 transition-colors">
              <div class="flex flex-col items-center justify-center pt-5 pb-6">
                <svg class="w-8 h-8 mb-3 text-pink-400" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 20 16">
                  <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 13h3a3 3 0 0 0 0-6h-.025A5.56 5.56 0 0 0 16 6.5 5.5 5.5 0 0 0 5.207 5.021C5.137 5.017 5.071 5 5 5a4 4 0 0 0 0 8h2.167M10 15V6m0 0L8 8m2-2 2 2"/>
                </svg>
                <p class="text-sm text-gray-600 text-center">
                  <span class="font-semibold text-pink-600">Clique para selecionar</span> ou arraste e solte
                </p>
                <p class="text-xs text-gray-400 mt-1">PNG, JPG, GIF, SVG ou WEBP</p>
              </div>
              <%= file_field_tag "secao[imagens][]", 
                    id: "secao_imagens",
                    accept: "image/*", 
                    multiple: true,
                    data: { action: "change->secao-form#handleImageSelect" },
                    class: "hidden" %>
            </label>
          </div>
        </div>
      </div>

      <%# ── Painel: Trilhas e Conteúdos ────────────────────────────────── %>
      <%# ── Painel: Trilhas e Conteúdos ────────────────────────────────── %>
      <div data-secao-form-target="conteudoPanel">

        <%# Seleção de itens — Trilhas %>
        <% if trilhas.any? %>
          <div class="mb-5">
            <p class="text-sm font-medium text-gray-700 mb-2">
              Trilhas
              <span class="text-xs font-normal text-gray-400 ml-1">(<%= trilhas.size %> disponíveis)</span>
            </p>
            <input type="text" 
                   placeholder="Buscar trilhas..."
                   data-secao-form-target="trilhasSearch"
                   data-action="input->secao-form#filterTrilhas"
                   class="w-full text-sm border border-gray-300 rounded-lg px-3 py-2 mb-2 focus:outline-none focus:ring-2 focus:ring-pink-300 focus:border-transparent">
            <div class="space-y-1 max-h-52 overflow-y-auto border border-gray-200 rounded-lg p-3 bg-gray-50" data-secao-form-target="trilhasList">
              <% trilhas.each do |trilha| %>
                <%
                  selected = secao.secao_itens.any? { |si|
                    si.item_type == "Universidade::Trilha" && si.item_id == trilha.id
                  }
                %>
                <label class="secao-item flex items-center gap-3 p-1.5 rounded-lg cursor-pointer hover:bg-white transition-colors group <%= 'is-selected' if selected %>" data-searchable="<%= trilha.nome.downcase %> <%= trilha.descricao.to_s.downcase %>">
                  <span class="text-gray-300 cursor-grab active:cursor-grabbing" data-sortable-handle>
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M9 6h.01M9 12h.01M9 18h.01M15 6h.01M15 12h.01M15 18h.01"/>
                    </svg>
                  </span>
                  <input type="checkbox"
                         name="secao[trilha_ids][]"
                         value="<%= trilha.id %>"
                         <%= "checked" if selected %>
                         data-action="change->secao-form#toggleSelection"
                         class="rounded border-gray-300 text-pink-600 focus:ring-pink-500 flex-shrink-0">
                  <div class="flex-1 min-w-0">
                    <p class="text-sm text-gray-800 truncate group-hover:text-pink-700 font-medium">
                      <%= trilha.nome %>
                    </p>
                    <% if trilha.descricao.present? %>
                      <p class="text-xs text-gray-400 truncate"><%= trilha.descricao %></p>
                    <% end %>
                  </div>
                  <% unless trilha.visivel? %>
                    <span class="text-xs text-gray-400 flex-shrink-0">oculto</span>
                  <% end %>
                </label>
              <% end %>
            </div>
            <p class="text-xs text-gray-400 mt-2">Arraste itens selecionados para reordená-los</p>
          </div>
        <% end %>

        <%# Seleção de itens — Conteúdos %>
        <% if conteudos.any? %>
          <div>
            <p class="text-sm font-medium text-gray-700 mb-2">
              Conteúdos
              <span class="text-xs font-normal text-gray-400 ml-1">(<%= conteudos.size %> disponíveis)</span>
            </p>
            <input type="text" 
                   placeholder="Buscar conteúdos..."
                   data-secao-form-target="conteudosSearch"
                   data-action="input->secao-form#filterConteudos"
                   class="w-full text-sm border border-gray-300 rounded-lg px-3 py-2 mb-2 focus:outline-none focus:ring-2 focus:ring-pink-300 focus:border-transparent">
            <div class="space-y-1 max-h-52 overflow-y-auto border border-gray-200 rounded-lg p-3 bg-gray-50" data-secao-form-target="conteudosList">
              <% conteudos.each do |conteudo| %>
                <%
                  selected = secao.secao_itens.any? { |si|
                    si.item_type == "Universidade::Conteúdo" && si.item_id == conteudo.id
                  }
                %>
                <label class="secao-item flex items-center gap-3 p-1.5 rounded-lg cursor-pointer hover:bg-white transition-colors group <%= 'is-selected' if selected %>" data-searchable="<%= conteudo.titulo.downcase %>">
                  <span class="text-gray-300 cursor-grab active:cursor-grabbing" data-sortable-handle>
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M9 6h.01M9 12h.01M9 18h.01M15 6h.01M15 12h.01M15 18h.01"/>
                    </svg>
                  </span>
                  <input type="checkbox"
                         name="secao[conteudo_ids][]"
                         value="<%= conteudo.id %>"
                         <%= "checked" if selected %>
                         data-action="change->secao-form#toggleSelection"
                         class="rounded border-gray-300 text-pink-600 focus:ring-pink-500 flex-shrink-0">
                  <p class="text-sm text-gray-800 truncate group-hover:text-pink-700 font-medium">
                    <%= conteudo.titulo %>
                  </p>
                  <% unless conteudo.visivel? %>
                    <span class="text-xs text-gray-400 flex-shrink-0">oculto</span>
                  <% end %>
                </label>
              <% end %>
            </div>
            <p class="text-xs text-gray-400 mt-2">Arraste itens selecionados para reordená-los</p>
          </div>
        <% end %>

        <% if trilhas.empty? && conteudos.empty? %>
          <p class="text-sm text-gray-400 italic py-4 text-center">
            Nenhuma trilha ou conteúdo cadastrado ainda.
          </p>
        <% end %>

      </div><%# /conteudoPanel %>
    </div>
  </div>

  <%# ══════════════════════════════════════════════════════ %>
  <%# VISIBILIDADE %>
  <%# ══════════════════════════════════════════════════════ %>
  <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-6">
    <div class="flex items-center justify-between">
      <div>
        <p class="text-sm font-medium text-gray-900">Visível na landing page</p>
        <p class="text-xs text-gray-500 mt-0.5">Quando ativado, esta seção será exibida publicamente.</p>
      </div>
      <label class="flex items-center cursor-pointer">
        <%= f.check_box :visivel, class: "sr-only peer" %>
        <div class="relative w-11 h-6 bg-gray-200 peer-focus:ring-2 peer-focus:ring-pink-500 rounded-full
                    peer peer-checked:bg-pink-500
                    after:content-[''] after:absolute after:top-[2px] after:left-[2px]
                    after:bg-white after:border-gray-300 after:border after:rounded-full
                    after:h-5 after:w-5 after:transition-all
                    peer-checked:after:translate-x-full peer-checked:after:border-white">
        </div>
      </label>
    </div>
  </div>

  <%# ── Botões ─────────────────────────────────────────────── %>
  <div class="flex justify-end gap-3 pb-6">
    <% if secao.new_record? %>
      <button type="button"
              data-action="click->modal#close"
              class="px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-lg hover:bg-gray-50 transition-colors">
        Cancelar
      </button>
    <% else %>
      <%= link_to "Cancelar", admin_secoes_path,
            class: "px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-lg hover:bg-gray-50 transition-colors" %>
    <% end %>
    <%= f.submit "Salvar seção",
          class: "px-6 py-2 text-sm font-medium text-white bg-pink-600 hover:bg-pink-700 rounded-lg transition-colors cursor-pointer" %>
  </div>

<% end %>
