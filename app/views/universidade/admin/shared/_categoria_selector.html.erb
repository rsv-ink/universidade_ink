<%
  # Parâmetros:
  # - form: form builder (obrigatório)
  # - field_name: nome do campo (padrão: :categoria_id)
  # - selected_value: valor selecionado (padrão: nil)
  # - label: texto do label (padrão: "Categoria")
  # - placeholder: texto do placeholder (padrão: "Nenhuma categoria")
  # - label_class: classes CSS do label (padrão: "block text-sm font-medium text-gray-700 mb-2")
  # - help_text: texto de ajuda (padrão: "Selecione uma categoria existente ou crie uma nova")
  # - show_help: mostrar texto de ajuda (padrão: true)
  # - input_class: classes adicionais para o input (padrão: "")
  # - auto_submit: submete o formulário automaticamente ao selecionar (padrão: false)
  
  field_name ||= :categoria_id
  selected_value ||= nil
  label ||= "Categoria"
  placeholder ||= "Nenhuma categoria"
  label_class ||= "block text-sm font-medium text-gray-700 mb-2"
  help_text ||= "Selecione uma categoria existente ou crie uma nova"
  show_help = true if show_help.nil?
  input_class ||= ""
  auto_submit ||= false
  
  # Buscar categoria selecionada se houver um valor
  selected_categoria = selected_value.present? ? Universidade::Categoria.find_by(id: selected_value) : nil
  display_text = selected_categoria ? selected_categoria.nome : placeholder
  
  # Classes padrão do botão
  base_button_class = "w-full px-3 py-2 text-left border border-gray-300 rounded-lg bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-pink-300 focus:border-transparent flex items-center justify-between"
  button_class = input_class.present? ? "#{base_button_class} #{input_class}" : base_button_class
%>

<div data-controller="categoria-selector" data-categoria-selector-auto-submit-value="<%= auto_submit %>">
  <%= form.label field_name, label, class: label_class %>
  
  <div class="relative">
    <div class="relative">
      <button type="button"
              data-action="click->categoria-selector#toggleDropdown"
              class="<%= button_class %>">
        <span data-categoria-selector-target="displayText" class="text-gray-700 <%= input_class %>">
          <%= display_text %>
        </span>
        <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
        </svg>
      </button>
      
      <div data-categoria-selector-target="dropdown"
           class="hidden absolute z-20 w-full mt-1 bg-white border border-gray-300 rounded-lg shadow-lg">
        <div class="p-3 border-b border-gray-200">
          <input type="text"
                 data-categoria-selector-target="searchInput"
                 data-action="input->categoria-selector#onInput"
                 placeholder="Buscar ou criar categoria..."
                 class="w-full px-3 py-2 text-sm border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-pink-300 focus:border-transparent">
        </div>
        <div class="max-h-48 overflow-auto">
          <div data-categoria-selector-target="dropdownResults" class="py-1">
          </div>
        </div>
      </div>
    </div>
    
    <%= form.hidden_field field_name,
          value: selected_value,
          data: { categoria_selector_target: "hiddenInput" } %>
  </div>
  
  <% if show_help %>
    <p class="mt-1 text-xs text-gray-500"><%= help_text %></p>
  <% end %>
</div>
