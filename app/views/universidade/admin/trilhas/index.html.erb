<%# ── Header ──────────────────────────────────────────────────── %>
<div class="px-6 py-6 max-w-7xl mx-auto">
  <div class="flex items-center justify-between mb-4">
    <div>
      <h1 class="text-2xl font-bold text-gray-900">Gestão de Trilha</h1>
    </div>
  </div>

  <%# ── Busca de conteúdo ── %>
  <%= form_with url: admin_root_path, method: :get, local: true,
        class: "flex items-center gap-2 mb-6" do |f| %>
    <%= f.search_field :q, value: @busca, placeholder: "Buscar trilhas, módulos e conteúdos...",
          class: "text-sm border border-gray-200 rounded-lg px-3 py-2 w-80 focus:outline-none focus:ring-2 focus:ring-pink-300 focus:border-transparent" %>
    <button type="submit"
            class="inline-flex items-center gap-1.5 px-4 py-2 bg-white hover:bg-gray-50 text-gray-600 text-sm font-medium rounded-lg transition-colors border border-gray-200">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-4.35-4.35M17 11A6 6 0 1 1 5 11a6 6 0 0 1 12 0z"/>
      </svg>
      Buscar
    </button>
  <% end %>

  <%# ── Tabela hierárquica ───────────────────────────────────── %>
  <div class="flex items-center justify-between mb-4">
    <h2 class="text-lg font-semibold text-gray-900">Trilhas</h2>
    <div class="flex items-center gap-3">
      <p class="text-xs text-gray-500"><%= @trilhas.size %> trilha(s)</p>
      <%= link_to new_admin_trilha_path,
            data: { controller: "modal-link", action: "click->modal-link#open", turbo: "false" },
            class: "inline-flex items-center gap-2 px-4 py-2 bg-pink-600 hover:bg-pink-700 text-white text-sm font-medium rounded-lg transition-colors" do %>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
        </svg>
        Nova Trilha
      <% end %>
    </div>
  </div>

  <div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden">
    <table class="w-full text-sm text-left text-gray-600"
           data-controller="hierarchical-sortable"
           data-hierarchical-sortable-trilha-url-value="<%= reorder_admin_trilhas_path %>"
           data-hierarchical-sortable-modulo-url-value="<%= reorder_admin_modulos_path %>"
           data-hierarchical-sortable-conteudo-url-value="<%= reorder_admin_conteudos_path %>">
      <thead class="text-xs font-semibold text-gray-500 uppercase tracking-wider bg-gray-50 border-b border-gray-200">
        <tr>
          <th class="px-4 py-3">Títulos</th>
          <th class="px-4 py-3 w-44 text-center">Status</th>
          <th class="px-4 py-3 w-40 text-right">Ações</th>
        </tr>
      </thead>

      <%# ── Trilhas com seus filhos (Módulos e Conteúdos) ──────────────────────────── %>
      <% if @trilhas.empty? %>
        <tbody>
          <tr>
            <td colspan="3" class="px-4 py-16 text-center text-gray-400 text-sm">
              Nenhuma trilha cadastrada ainda.
              <%= link_to "Criar a primeira trilha", new_admin_trilha_path,
                    data: { controller: "modal-link", action: "click->modal-link#open", turbo: "false" },
                    class: "text-pink-600 hover:underline font-medium" %>
            </td>
          </tr>
        </tbody>
      <% else %>
        <% @trilhas.each do |trilha| %>
          <tbody id="trilha_group_<%= trilha.id %>"
                 data-sortable-id="<%= trilha.id %>"
                 data-controller="accordion"
                 data-accordion-open-value="false"
                 data-accordion-group-value="trilha_<%= trilha.id %>">

            <%= render "trilha", trilha: trilha %>

            <%# Módulos da trilha %>
            <% trilha.modulos.order(Arel.sql("COALESCE(ordem, id)")).each do |modulo| %>
              <%= render "universidade/admin/modulos/modulo_row", modulo: modulo %>

              <%# Conteúdos do módulo através de trilha_conteudos %>
              <% trilha.trilha_conteudos.where(modulo_id: modulo.id).order(:posicao).each do |tc| %>
                <%= render "universidade/admin/conteudos/conteudo_row",
                      conteudo: tc.conteudo,
                      parent_type: "modulo",
                      parent_id: modulo.id %>
              <% end %>
            <% end %>

            <%# Conteúdos vinculados diretamente à trilha (sem módulo) %>
            <% trilha.trilha_conteudos.where(modulo_id: nil).order(:posicao).each do |tc| %>
              <%= render "universidade/admin/conteudos/conteudo_row",
                    conteudo: tc.conteudo,
                    parent_type: "trilha",
                    parent_id: trilha.id %>
            <% end %>

          </tbody>
        <% end %>
      <% end %>

      <%# ── Conteúdo avulso (sem trilha) ─────────────────────────────────── %>
      <% tem_avulsos = @modulos_avulsos.any? %>
      <% if tem_avulsos %>
        <tbody>
          <tr>
            <td colspan="3" class="px-4 py-2 text-xs font-semibold text-gray-400 uppercase tracking-wider bg-gray-50 border-t border-gray-200">
              Conteúdo avulso (sem vínculo)
            </td>
          </tr>
        </tbody>

        <tbody id="avulso_group">
          <% @modulos_avulsos.each do |modulo| %>
            <%= render "universidade/admin/modulos/modulo_row", modulo: modulo %>
          <% end %>
        </tbody>
      <% end %>

    </table>
  </div>
</div>
