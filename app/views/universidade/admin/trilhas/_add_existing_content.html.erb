<div class="p-6">
  <% modulo_id = params[:modulo_id] %>
  <div class="flex items-center justify-between mb-4">
    <h3 class="text-lg font-semibold text-gray-900">
      <%= modulo_id ? "Adicionar Conteúdos ao Módulo" : "Adicionar Conteúdos à Trilha" %>
    </h3>
    <%= link_to new_admin_biblioteca_path(trilha_id: @trilha.id, modulo_id: modulo_id),
          class: "inline-flex items-center gap-1.5 px-3 py-1.5 bg-pink-600 hover:bg-pink-700 text-white text-sm font-medium rounded-lg transition-colors" do %>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
      </svg>
      Criar Novo
    <% end %>
  </div>
  
  <%= form_with url: adicionar_conteudos_existentes_admin_trilha_path(@trilha, modulo_id: modulo_id), method: :post, class: "space-y-4" do |f| %>
    <%= hidden_field_tag :modulo_id, modulo_id if modulo_id %>
    <%# Campo de busca %>
    <div>
      <label class="block text-sm font-medium text-gray-700 mb-2">Buscar conteúdos</label>
      <input type="text" 
             id="conteudo-search"
             placeholder="Digite para buscar por título..."
             class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-pink-300 focus:border-transparent">
    </div>
    
    <%# Lista de conteúdos disponíveis %>
    <div class="max-h-96 overflow-y-auto border border-gray-200 rounded-lg">
      <% if @conteudos_disponiveis.empty? %>
        <div class="p-8 text-center text-gray-500">
          <p>Nenhum conteúdo disponível na biblioteca.</p>
          <%= link_to "Criar novo conteúdo", new_admin_biblioteca_path, 
                class: "text-pink-600 hover:underline font-medium", 
                target: "_blank" %>
        </div>
      <% else %>
        <div class="divide-y divide-gray-100">
          <% @conteudos_disponiveis.each do |conteudo| %>
            <label class="flex items-start gap-3 p-3 hover:bg-gray-50 cursor-pointer conteudo-item" 
                   data-titulo="<%= conteudo.titulo.downcase %>">
              <%= check_box_tag "conteudo_ids[]", conteudo.id, false, 
                    class: "mt-1 w-4 h-4 text-pink-600 border-gray-300 rounded focus:ring-pink-500" %>
              <div class="flex-1">
                <p class="font-medium text-gray-900"><%= conteudo.titulo %></p>
                <% if conteudo.trilhas_count > 0 %>
                  <p class="text-xs text-gray-500 mt-1">
                    Já está em <%= conteudo.trilhas_count %> trilha(s)
                  </p>
                <% else %>
                  <p class="text-xs text-amber-600 mt-1">
                    <svg class="inline w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
                    </svg>
                    Sem trilha
                  </p>
                <% end %>
              </div>
            </label>
          <% end %>
        </div>
      <% end %>
    </div>
    
    <%# Ações %>
    <div class="flex items-center justify-end gap-3 pt-4 border-t border-gray-200">
      <button type="button"
              onclick="document.getElementById('modal').classList.add('hidden')"
              class="px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-lg hover:bg-gray-50 transition-colors">
        Cancelar
      </button>
      <%= f.submit "Adicionar Selecionados",
            class: "px-4 py-2 text-sm font-medium text-white bg-pink-600 rounded-lg hover:bg-pink-700 transition-colors" %>
    </div>
  <% end %>
</div>

<script>
  // Busca em tempo real
  document.getElementById('conteudo-search').addEventListener('input', function(e) {
    const searchTerm = e.target.value.toLowerCase();
    const items = document.querySelectorAll('.conteudo-item');
    
    items.forEach(item => {
      const titulo = item.dataset.titulo;
      if (titulo.includes(searchTerm)) {
        item.style.display = 'flex';
      } else {
        item.style.display = 'none';
      }
    });
  });
</script>
