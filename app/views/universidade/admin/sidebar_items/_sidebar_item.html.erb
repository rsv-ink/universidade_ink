<div id="sidebar_item_<%= sidebar_item.id %>"
  data-sortable-id="<%= sidebar_item.id %>"
  class="p-4 flex items-center gap-4 transition-all hover:bg-gray-50 <%= 'opacity-60' unless sidebar_item.visivel? %>">

  <div class="flex items-center gap-3 flex-shrink-0">
    <%# Drag handle %>
    <div class="cursor-grab active:cursor-grabbing text-gray-400 hover:text-gray-600" data-sortable-handle>
      <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
        <path d="M7 2a2 2 0 1 0 .001 4.001A2 2 0 0 0 7 2zm0 6a2 2 0 1 0 .001 4.001A2 2 0 0 0 7 8zm0 6a2 2 0 1 0 .001 4.001A2 2 0 0 0 7 14zm6-8a2 2 0 1 0-.001-4.001A2 2 0 0 0 13 6zm0 2a2 2 0 1 0 .001 4.001A2 2 0 0 0 13 8zm0 6a2 2 0 1 0 .001 4.001A2 2 0 0 0 13 14z"/>
      </svg>
    </div>

    <%# Ícone de tipo %>
    <% if sidebar_item.link? %>
      <div class="flex-shrink-0 w-5 h-5 text-gray-500">
        <% if sidebar_item.icone.present? %>
          <%= sidebar_item.icone.html_safe %>
        <% else %>
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"/>
          </svg>
        <% end %>
      </div>
    <% else %>
      <svg class="w-5 h-5 text-gray-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 12H4"/>
      </svg>
    <% end %>
  </div>

  <%# Info %>
  <div class="flex-1 min-w-0">
    <p class="font-semibold text-gray-900 truncate <%= 'line-through text-gray-400' unless sidebar_item.visivel? %>">
      <%= sidebar_item.nome %>
    </p>
    <div class="flex items-center gap-2 mt-1 flex-wrap text-xs text-gray-500">
      <% if sidebar_item.link? %>
        <span class="px-2 py-0.5 rounded-full bg-blue-100 text-blue-700 font-medium">Link</span>
        <% if sidebar_item.url.present? %>
          <span class="text-gray-300">·</span>
          <span class="truncate max-w-xs"><%= sidebar_item.url %></span>
        <% end %>
      <% else %>
        <span class="px-2 py-0.5 rounded-full bg-gray-100 text-gray-600 font-medium">Divisor</span>
      <% end %>
    </div>
  </div>

  <%# Ações %>
  <div class="flex items-center gap-1 flex-shrink-0">

    <%# Visibilidade %>
    <%= button_to toggle_visivel_admin_sidebar_item_path(sidebar_item),
          method: :patch,
          class: "inline-flex items-center gap-1.5 px-2.5 py-1.5 rounded-md text-xs font-medium transition-colors #{sidebar_item.visivel? ? 'bg-green-50 text-green-700 hover:bg-green-100' : 'bg-gray-100 text-gray-600 hover:bg-gray-200'}" do %>
      <% if sidebar_item.visivel? %>
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
        </svg>
        Visível
      <% else %>
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268 2.943 9.543 7a10.025 10.025 0 01-4.132 5.411m0 0L21 21"/>
        </svg>
        Invisível
      <% end %>
    <% end %>

    <%# Editar %>
    <%= link_to edit_admin_sidebar_item_path(sidebar_item),
          data: { turbo_stream: true },
          title: "Editar",
          class: "p-1.5 text-gray-400 hover:text-blue-600 hover:bg-blue-50 rounded transition-colors" do %>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
      </svg>
    <% end %>

    <%# Excluir %>
    <%= button_to admin_sidebar_item_path(sidebar_item),
          method: :delete,
          form: { data: { turbo_confirm: "Tem certeza que deseja excluir \"#{sidebar_item.nome}\"?" } },
          title: "Excluir",
          class: "p-1.5 text-gray-400 hover:text-red-600 hover:bg-red-50 rounded transition-colors" do %>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
      </svg>
    <% end %>

  </div>

</div>
