<%# locals: conteudo, from_curso_id (optional) %>
<li id="artigo_<%= conteudo.id %>"
  data-sortable-id="<%= conteudo.id %>"
  class="flex flex-wrap sm:flex-nowrap items-center gap-2 sm:gap-3 py-1.5 group w-full max-w-full overflow-hidden <%= conteudo.visivel? ? '' : 'opacity-60' %>">

  <span data-sortable-handle
        class="text-gray-300 hover:text-gray-400 cursor-grab active:cursor-grabbing flex-shrink-0 self-start sm:self-center"
        title="Arrastar para reordenar">
    <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24">
      <path d="M8 6a2 2 0 110-4 2 2 0 010 4zM8 14a2 2 0 110-4 2 2 0 010 4zM8 22a2 2 0 110-4 2 2 0 010 4zM16 6a2 2 0 110-4 2 2 0 010 4zM16 14a2 2 0 110-4 2 2 0 010 4zM16 22a2 2 0 110-4 2 2 0 010 4z"/>
    </svg>
  </span>

  <%= form_with url: toggle_visivel_admin_conteudo_path(conteudo), method: :patch, class: "inline" do %>
    <button type="submit" title="<%= conteudo.visivel? ? 'Ocultar' : 'Publicar' %>"
            class="w-1.5 h-1.5 rounded-full flex-shrink-0
                   <%= conteudo.visivel? ? 'bg-green-400' : 'bg-gray-300' %>">
    </button>
  <% end %>

  <div class="w-full sm:flex-1 text-sm text-gray-700 truncate min-w-0 flex items-center gap-2">
    <span class="truncate"><%= conteudo.titulo %></span>
    <% if conteudo.tempo_estimado_minutos.present? && conteudo.tempo_estimado_minutos > 0 %>
      <span class="text-xs text-gray-400 flex-shrink-0">(<%= conteudo.tempo_estimado_minutos %> min)</span>
    <% end %>
    <% if conteudo.rascunho? %>
      <span class="inline-flex items-center gap-1.5 text-xs font-medium px-2 py-0.5 rounded-full bg-amber-100 text-amber-700">
        Rascunho
      </span>
    <% else %>
      <%= button_to toggle_visivel_admin_conteudo_path(conteudo),
            method: :patch,
            class: "inline-flex items-center gap-1.5 px-2.5 py-1.5 rounded-md text-xs font-medium transition-colors #{conteudo.visivel? ? 'bg-green-50 text-green-700 hover:bg-green-100' : 'bg-gray-100 text-gray-600 hover:bg-gray-200'}" do %>
        <% if conteudo.visivel? %>
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
          </svg>
          Visível
        <% else %>
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268 2.943 9.543 7a10.025 10.025 0 01-4.132 5.411m0 0L21 21"/>
          </svg>
          Invisível
        <% end %>
      <% end %>
    <% end %>
  </div>

  <div class="flex items-center gap-1 ml-2 opacity-100 transition-opacity flex-shrink-0">
            <%= link_to edit_admin_biblioteca_path(conteudo),
              data: { turbo_frame: "_top" },
              class: "p-1 text-gray-400 hover:text-blue-600 hover:bg-blue-50 rounded transition-colors" do %>
      <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
      </svg>
    <% end %>

    <%= link_to admin_biblioteca_path(conteudo),
          data: { turbo_method: :delete, turbo_confirm: "Excluir o conteudo \"#{conteudo.titulo}\"?" },
          class: "p-1 text-gray-400 hover:text-red-600 hover:bg-red-50 rounded transition-colors" do %>
      <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
      </svg>
    <% end %>
  </div>
</li>
