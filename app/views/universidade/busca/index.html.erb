<%# ════════════════════════════════════════════════════════════
    MODO 1 — Navegação por categoria (?categoria=slug)
    ════════════════════════════════════════════════════════════ %>
<% if @categoria %>

  <%# Cabeçalho %>
  <div class="mb-8">
    <%= link_to busca_path, class: "inline-flex items-center gap-1 text-sm text-gray-400 hover:text-pink-500 transition-colors mb-4" do %>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
      </svg>
      Todas as categorias
    <% end %>
    <h1 class="text-2xl font-bold text-gray-900"><%= @categoria.nome %></h1>
    <p class="text-sm text-gray-500 mt-1">
      <%= @conteudos.size %> <%= @conteudos.size == 1 ? "conteúdo" : "conteúdos" %> nesta categoria
    </p>
  </div>

  <% if @conteudos.any? %>
    <div class="space-y-2">
      <% @conteudos.each do |conteudo| %>
        <%= link_to conteudo_path(conteudo), class: "flex items-center gap-4 bg-white border border-gray-200 rounded-lg px-4 py-3 hover:border-pink-300 hover:shadow-sm transition-all group" do %>
          <svg class="w-5 h-5 text-gray-300 group-hover:text-pink-400 transition-colors shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
          </svg>
          <div class="flex-1 min-w-0">
            <p class="text-sm font-medium text-gray-900 group-hover:text-pink-600 transition-colors truncate"><%= conteudo.titulo %></p>
            <% trilha = conteudo.trilha_contexto %>
            <% if trilha %>
              <p class="text-xs text-gray-400 mt-0.5 truncate">em <%= trilha.nome %></p>
            <% end %>
          </div>
          <svg class="w-4 h-4 text-gray-300 group-hover:text-pink-400 transition-colors shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
          </svg>
        <% end %>
      <% end %>
    </div>
  <% else %>
    <div class="py-16 text-center text-gray-400">
      <svg class="w-12 h-12 mx-auto mb-4 text-gray-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
      </svg>
      <p class="text-sm">Nenhum conteúdo publicado nesta categoria ainda.</p>
    </div>
  <% end %>

<%# ════════════════════════════════════════════════════════════
    MODO 2 — Resultados de busca (?q=termo)
    ════════════════════════════════════════════════════════════ %>
<% elsif @q.present? %>

  <%# Campo de refinamento de busca %>
  <div class="mb-6">
    <%= form_with url: busca_path, method: :get, local: true,
          data: { action: "submit->analytics#trackSearch" },
          class: "flex items-center gap-2 max-w-xl" do |f| %>
      <%= f.search_field :q, value: @q, placeholder: "Buscar trilhas e conteúdos...",
            autofocus: false,
            class: "flex-1 text-sm border border-gray-200 rounded-full px-5 py-2.5 focus:outline-none focus:ring-2 focus:ring-pink-300 focus:border-transparent shadow-sm" %>
      <button type="submit"
              class="inline-flex items-center gap-2 px-4 py-2.5 bg-pink-600 hover:bg-pink-700 text-white text-sm font-medium rounded-full transition-colors shadow-sm">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-4.35-4.35M17 11A6 6 0 1 1 5 11a6 6 0 0 1 12 0z"/>
        </svg>
        Buscar
      </button>
    <% end %>
  </div>

  <% sem_resultados = @trilhas.empty? && @conteudos.empty? %>

  <% if sem_resultados %>
    <div class="py-16 text-center text-gray-400">
      <svg class="w-12 h-12 mx-auto mb-4 text-gray-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
      </svg>
      <p class="text-base font-medium text-gray-500 mb-1">Nenhum resultado para "<%= @q %>"</p>
      <p class="text-sm">Tente palavras diferentes ou verifique a ortografia.</p>
    </div>

  <% else %>

    <%# Cabeçalho com contagem %>
    <div class="mb-4">
      <h1 class="text-xl font-bold text-gray-900">
        Resultados para "<%= @q %>"
      </h1>
      <p class="text-sm text-gray-500 mt-0.5">
        <%= [@trilhas.size, @conteudos.size].sum %> resultado(s) encontrado(s)
      </p>
    </div>

    <%# Chips de filtro por categoria %>
    <% if @categorias_filtro.any? %>
      <div class="flex flex-wrap gap-2 mb-6">
        <%= link_to "Todos", busca_path(q: @q),
              class: "px-3 py-1 rounded-full text-xs font-medium transition-colors #{@categoria_filtrada_id ? 'bg-gray-100 text-gray-600 hover:bg-gray-200' : 'bg-pink-600 text-white'}" %>
        <% @categorias_filtro.each do |cat| %>
          <%= link_to cat.nome, busca_path(q: @q, cat: cat.id),
                class: "px-3 py-1 rounded-full text-xs font-medium transition-colors #{@categoria_filtrada_id == cat.id ? 'bg-pink-600 text-white' : 'bg-gray-100 text-gray-600 hover:bg-gray-200'}" %>
        <% end %>
      </div>
    <% end %>

    <%# ── Trilhas ── %>
    <% if @trilhas.any? %>
      <section class="mb-10">
        <h2 class="text-sm font-semibold text-gray-700 mb-3 flex items-center gap-2">
          <svg class="w-4 h-4 text-pink-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/>
          </svg>
          Trilhas
          <span class="font-normal text-gray-400">(<%= @trilhas.size %>)</span>
        </h2>

        <div class="space-y-2">
          <% @trilhas.each do |trilha| %>
            <%= link_to trilha_path(trilha), class: "flex items-start gap-4 bg-white border border-gray-200 rounded-lg px-4 py-3 hover:border-pink-300 hover:shadow-sm transition-all group" do %>
              <div class="w-10 h-10 rounded-lg bg-pink-50 flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-pink-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/>
                </svg>
              </div>
              <div class="flex-1 min-w-0">
                <p class="text-sm font-semibold text-gray-900 group-hover:text-pink-600 transition-colors"><%= trilha.nome %></p>
                <% if trilha.descricao.present? %>
                  <p class="text-xs text-gray-500 mt-0.5 line-clamp-2"><%= trilha.descricao %></p>
                <% end %>
                <div class="flex items-center gap-3 mt-1.5">
                  <span class="text-xs text-gray-400">
                    <%= trilha.conteudos.visivel.count %> <%= trilha.conteudos.visivel.count == 1 ? "conteúdo" : "conteúdos" %>
                  </span>
                  <% trilha.tags.first(3).each do |tag| %>
                    <span class="text-xs bg-blue-50 text-blue-600 rounded-full px-2 py-0.5"><%= tag.nome %></span>
                  <% end %>
                </div>
              </div>
              <svg class="w-4 h-4 text-gray-300 group-hover:text-pink-400 transition-colors shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
              </svg>
            <% end %>
          <% end %>
        </div>
      </section>
    <% end %>

    <%# ── Conteúdos ── %>
    <% if @conteudos.any? %>
      <section class="mb-10">
        <h2 class="text-sm font-semibold text-gray-700 mb-3 flex items-center gap-2">
          <svg class="w-4 h-4 text-teal-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
          </svg>
          Conteúdos
          <span class="font-normal text-gray-400">(<%= @conteudos.size %>)</span>
        </h2>

        <div class="space-y-2">
          <% @conteudos.each do |conteudo| %>
            <%= link_to conteudo_path(conteudo), class: "flex items-center gap-4 bg-white border border-gray-200 rounded-lg px-4 py-3 hover:border-pink-300 hover:shadow-sm transition-all group" do %>
              <svg class="w-5 h-5 text-gray-300 group-hover:text-teal-400 transition-colors shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
              </svg>
              <div class="flex-1 min-w-0">
                <p class="text-sm font-medium text-gray-900 group-hover:text-pink-600 transition-colors truncate"><%= conteudo.titulo %></p>
                <div class="flex items-center gap-2 mt-0.5 flex-wrap">
                  <% trilha = conteudo.trilha_contexto %>
                  <% if trilha %>
                    <span class="text-xs text-gray-400 truncate">em <%= trilha.nome %></span>
                  <% end %>
                  <% if conteudo.categoria %>
                    <span class="text-xs bg-pink-50 text-pink-600 rounded-full px-2 py-0.5"><%= conteudo.categoria.nome %></span>
                  <% end %>
                </div>
              </div>
              <svg class="w-4 h-4 text-gray-300 group-hover:text-pink-400 transition-colors shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
              </svg>
            <% end %>
          <% end %>
        </div>
      </section>
    <% end %>

  <% end %>

<%# ════════════════════════════════════════════════════════════
    MODO 3 — Sem termo: navegação por categorias
    ════════════════════════════════════════════════════════════ %>
<% else %>

  <%# Campo de busca principal %>
  <div class="mb-10">
    <%= form_with url: busca_path, method: :get, local: true,
          data: { action: "submit->analytics#trackSearch" },
          class: "flex items-center gap-2 max-w-xl" do |f| %>
      <%= f.search_field :q, placeholder: "Buscar trilhas e conteúdos...",
            autofocus: true,
            class: "flex-1 text-sm border border-gray-200 rounded-full px-5 py-2.5 focus:outline-none focus:ring-2 focus:ring-pink-300 focus:border-transparent shadow-sm" %>
      <button type="submit"
              class="inline-flex items-center gap-2 px-4 py-2.5 bg-pink-600 hover:bg-pink-700 text-white text-sm font-medium rounded-full transition-colors shadow-sm">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-4.35-4.35M17 11A6 6 0 1 1 5 11a6 6 0 0 1 12 0z"/>
        </svg>
        Buscar
      </button>
    <% end %>
  </div>

  <% if @categorias.any? %>
    <div>
      <h2 class="text-sm font-semibold text-gray-700 mb-4">Navegar por categoria</h2>
      <div class="flex flex-wrap gap-3">
        <% @categorias.each do |cat| %>
          <%= link_to busca_path(categoria: cat.slug),
                class: "group flex items-center gap-2 bg-white border border-gray-200 hover:border-pink-300 hover:shadow-sm rounded-full px-4 py-2 transition-all" do %>
            <div class="w-6 h-6 rounded-full bg-pink-50 flex items-center justify-center">
              <svg class="w-3 h-3 text-pink-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"/>
              </svg>
            </div>
            <span class="text-sm text-gray-700 group-hover:text-pink-600 transition-colors font-medium"><%= cat.nome %></span>
          <% end %>
        <% end %>
      </div>
    </div>
  <% else %>
    <div class="py-16 text-center text-gray-400">
      <svg class="w-12 h-12 mx-auto mb-4 text-gray-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 21l-4.35-4.35M17 11A6 6 0 1 1 5 11a6 6 0 0 1 12 0z"/>
      </svg>
      <p class="text-sm">Digite um termo acima para encontrar trilhas e conteúdos.</p>
    </div>
  <% end %>

<% end %>
